# Copy to .env and fill in GROQ_API_KEY. Everything else has working defaults.

# --- App / API ---
APP_NAME=RAG API
API_V1_PREFIX=/api/v1
# JSON list. Use ["*"] for any origin, or lock down to your frontend(s):
# CORS_ORIGINS=["http://localhost:5173"]
CORS_ORIGINS=["*"]

# --- Uploads ---
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=25

# --- Embeddings ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval ---
RETRIEVAL_TOP_K=4

# --- Chroma vector store ---
CHROMA_PERSIST_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=documents

# --- LLM (Groq) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
